{
  "name": "statemesh-core",
  "version": "1.0.1",
  "description": "A TypeScript-first, transaction-first state orchestration library for React. Actions, computed state, async transactions, optimistic UI, rollback, persistence, URL state, forms, cross-tab sync, undo/redo, time travel, middleware pipelines, router, and testing helpers.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./persist": {
      "types": "./dist/persist/index.d.ts",
      "import": "./dist/persist/index.js",
      "require": "./dist/persist/index.cjs"
    },
    "./sync": {
      "types": "./dist/sync/index.d.ts",
      "import": "./dist/sync/index.js",
      "require": "./dist/sync/index.cjs"
    },
    "./resources": {
      "types": "./dist/resources/index.d.ts",
      "import": "./dist/resources/index.js",
      "require": "./dist/resources/index.cjs"
    },
    "./devtools": {
      "types": "./dist/devtools/index.d.ts",
      "import": "./dist/devtools/index.js",
      "require": "./dist/devtools/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "import": "./dist/router/index.js",
      "require": "./dist/router/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:clean": "tsup && find dist -name '*.map' -delete",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "tsd",
    "lint": "eslint src tests",
    "bench": "tsx benchmarks/basic.ts",
    "docs:dev": "npm run --prefix docs dev",
    "docs:build": "npm run --prefix docs build",
    "docs:preview": "npm run --prefix docs preview",
    "prepublishOnly": "npm run typecheck && npm test && npm run build:clean && npm run test:types"
  },
  "keywords": [
    "react",
    "statemesh",
    "state-management",
    "state",
    "store",
    "transactions",
    "optimistic-ui",
    "typescript",
    "url-state",
    "forms",
    "middleware",
    "undo-redo",
    "time-travel",
    "persistence",
    "cross-tab-sync",
    "router",
    "resource-cache",
    "api-client"
  ],
  "author": "Aditya Prakash",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/React-Statemesh/react-statemesh.git"
  },
  "bugs": {
    "url": "https://github.com/React-Statemesh/react-statemesh/issues"
  },
  "homepage": "https://react-statemesh.github.io/statemesh-docs/",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/React-Statemesh"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "eslint": "^9.29.0",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsd": "^0.32.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "tsd": {
    "directory": "test-d"
  }
}
